# Local fake API base URL. Run: npm run server or npm run mock:api
VITE_API_BASE_URL=http://localhost:3000

# Cloud Fake API base URL for TB1, when a JSON API endpoint is available.
# The value must point to the API root, not to a webapp hash route.
# VITE_API_BASE_URL=https://your-cloud-fake-api.example.com

