# ── Mock API (TB1 — json-server) ──────────────────────────────────────────────
# Local mock API base URL. Run: npm run server or npm run mock:api
VITE_API_BASE_URL=http://localhost:3000

# ── Nexa Platform backend integration ────────────────────────────────────────
# ASP.NET Core local API. Use http://localhost:5000/api/v1 if HTTPS certificates are not trusted.
VITE_NEXA_API_BASE_URL=https://localhost:7001/api/v1
VITE_ENABLE_MOCK_API_FALLBACK=true
VITE_CORE_BACKEND_ENABLED=false

# Cloud Mock API base URL for TB1, when a JSON API endpoint is available.
# The value must point to the API root, not to a webapp hash route.
# VITE_API_BASE_URL=https://your-cloud-mock-api.example.com

# ── Deployed URLs ─────────────────────────────────────────────────────────────
