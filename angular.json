{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "nexa-webapp": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "nx",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/nexa-webapp",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              { "glob": "favicon.svg", "input": "public", "output": "/" },
              { "glob": "**/*", "input": "public/assets", "output": "/assets" },
              { "glob": "**/*", "input": "public/api", "output": "/api" }
            ],
            "styles": [
              "node_modules/primeicons/primeicons.css",
              "src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "1mb", "maximumError": "3mb" },
                { "type": "anyComponentStyle", "maximumWarning": "8kb", "maximumError": "20kb" }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": { "port": 5173 },
          "configurations": {
            "production": { "buildTarget": "nexa-webapp:build:production" },
            "development": { "buildTarget": "nexa-webapp:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
